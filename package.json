{
	"name": "generator-nsis",
	"version": "0.13.1",
	"description": "Yeoman generator for NSIS scripts",
	"author": "Jan T. Sott",
	"license": "MIT",
	"keywords": [
		"yeoman-generator",
		"nsis",
		"nullsoft",
		"installer",
		"setup"
	],
	"type": "module",
	"exports": "./generators/app/index.js",
	"files": [
		"generators",
		"lib",
		"LICENSE",
		"README.md"
	],
	"scripts": {
		"lint:e18e": "e18e-cli analyze",
		"lint:code": "biome check",
		"lint": "concurrently --prefix '{name}' -c 'green,blue' 'npm:lint:*'",
		"publish:npm": "np",
		"test": "uvu --ignore tests/__helper.js"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/idleberg/generator-nsis.git"
	},
	"engines": {
		"node": ">=22"
	},
	"dependencies": {
		"@idleberg/yeoman-generator": "^0.2.0",
		"@nsis/language-data": "^0.11.0",
		"@sindresorhus/slugify": "^3.0.0",
		"kleur": "^4.1.5",
		"makensis": "3.0.4",
		"semver": "^7.7.4",
		"spdx-license-list": "^6.11.0",
		"terminal-link": "^5.0.0"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@idleberg/configs": "^0.4.2",
		"@lukeed/uuid": "^2.0.1",
		"@types/node": "^24.12.0",
		"concurrently": "^9.2.1",
		"np": "^11.0.2",
		"tsm": "^2.3.0",
		"typescript": "^6.0.2",
		"uvu": "^0.5.6",
		"yeoman-assert": "^3.1.1",
		"yeoman-environment": "^6.0.0",
		"yeoman-test": "^11.3.1"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"lefthook"
		]
	},
	"packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
